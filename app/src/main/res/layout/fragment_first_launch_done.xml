<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="24dp"
    android:paddingTop="22dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp">

    <LinearLayout
        android:id="@+id/content_first_launch_done"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/image_first_launch_done"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:alpha="0.92"
            android:contentDescription="@null"
            android:padding="6dp"
            android:src="@drawable/ic_first_launch_done_check"
            app:tint="#F4F9FBFF" />

        <TextView
            android:id="@+id/text_first_launch_done_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/samsungsharpsans"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="5dp"
            android:shadowColor="#3A000000"
            android:shadowDx="0"
            android:shadowDy="8"
            android:shadowRadius="18"
            android:text="@string/first_launch_done_title"
            android:textColor="#FFF9FBFF"
            android:textSize="42sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_first_launch_done_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_first_launch_done_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="72dp"
            android:fontFamily="@font/samsungone"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="4dp"
            android:shadowColor="#26000000"
            android:shadowDx="0"
            android:shadowDy="6"
            android:shadowRadius="12"
            android:text="@string/first_launch_done_subtitle"
            android:textColor="#EAF9FBFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/button_first_launch_done"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_first_launch_primary_button"
            android:fontFamily="@font/samsungsharpsans"
            android:text="@string/first_launch_continue"
            android:textColor="#FF010102"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
