<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?roundedCornerColor"
    app:expanded="false"
    app:expandable="false"
    app:title="@string/captcha_browser_title">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <dev.oneuiproject.oneui.widget.RoundedLinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:colorBackground"
            android:orientation="vertical"
            android:padding="20dp"
            app:roundedCorners="all">

            <TextView
                android:id="@+id/text_captcha_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/captcha_browser_headline"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="?android:textColorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_captcha_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/captcha_browser_subtitle"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:textColorSecondary" />

            <LinearLayout
                android:id="@+id/layout_captcha_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_surface_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp">

                <TextView
                    android:id="@+id/text_captcha_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/captcha_browser_status_loading"
                    android:textColor="?android:textColorPrimary"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progress_captcha_status"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="10dp"
                    android:indeterminate="true" />
            </LinearLayout>

            <Button
                android:id="@+id/button_captcha_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minWidth="0dp"
                android:text="@string/captcha_browser_cancel" />
        </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1">

            <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?android:colorBackground"
                android:orientation="vertical"
                android:padding="0dp"
                app:roundedCorners="all">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_surface_card"
                    android:clipToPadding="true"
                    android:clipChildren="true">

                    <WebView
                        android:id="@+id/webview_captcha"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:id="@+id/layout_captcha_progress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top"
                        android:background="?android:colorBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">

                        <ProgressBar
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:indeterminate="true" />

                        <TextView
                            android:id="@+id/text_captcha_progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/captcha_browser_progress"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="?android:textColorSecondary" />
                    </LinearLayout>
                </FrameLayout>
            </dev.oneuiproject.oneui.widget.RoundedLinearLayout>
        </FrameLayout>
    </LinearLayout>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
