<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?roundedCornerColor"
    app:expanded="false"
    app:expandable="false"
    app:title="@string/auto_search_title">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:id="@+id/layout_auto_search_setup_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:colorBackground"
                    android:orientation="vertical"
                    android:padding="20dp"
                    app:roundedCorners="all">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_search_header_title"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="?android:textColorPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/text_auto_search_header_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/auto_search_header_summary"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary" />
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <dev.oneuiproject.oneui.widget.Separator
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_search_actions_section" />

                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:colorBackground"
                    android:orientation="vertical"
                    app:roundedCorners="all">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <dev.oneuiproject.oneui.widget.CardItemView
                            android:id="@+id/row_start_auto_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:showBottomDivider="false"
                            app:showTopDivider="false"
                            app:summary="@string/auto_search_start_summary"
                            app:title="@string/auto_search_start_title" />

                        <ProgressBar
                            android:id="@+id/progress_start_auto_search"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="18dp"
                            android:visibility="gone" />
                    </FrameLayout>
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <dev.oneuiproject.oneui.widget.Separator
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_search_settings_section" />

                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:colorBackground"
                    android:orientation="vertical"
                    app:roundedCorners="all">

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_auto_search_target_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:showTopDivider="false"
                        app:title="@string/auto_search_setting_target_count" />

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_auto_search_tcping_timeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title="@string/auto_search_setting_tcping_timeout" />

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_auto_search_download_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title="@string/auto_search_setting_download_size" />

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_auto_search_download_timeout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:title="@string/auto_search_setting_download_timeout" />

                    <dev.oneuiproject.oneui.widget.CardItemView
                        android:id="@+id/row_auto_search_download_attempts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:showBottomDivider="false"
                        app:title="@string/auto_search_setting_download_attempts" />
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_auto_search_run_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:colorBackground"
                    android:orientation="vertical"
                    android:padding="20dp"
                    app:roundedCorners="all">

                    <TextView
                        android:id="@+id/text_auto_search_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_auto_search_state_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="?android:textColorPrimary"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progress_auto_search_state"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="12dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_auto_search_state_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary" />

                    <ProgressBar
                        android:id="@+id/progress_auto_search_overall"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:max="100"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/text_auto_search_progress_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:id="@+id/text_auto_search_metric_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorPrimary" />

                    <TextView
                        android:id="@+id/text_auto_search_speed_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary" />

                    <TextView
                        android:id="@+id/text_auto_search_found_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary"
                        android:textStyle="bold" />
                </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

                <dev.oneuiproject.oneui.widget.Separator
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_search_checked_profiles_section" />

                <LinearLayout
                    android:id="@+id/container_auto_search_profile_chain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
