<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="24dp"
    android:paddingTop="26dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_auto_search_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_first_launch_badge"
            android:fontFamily="@font/samsungone"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:text="@string/auto_search_status_idle"
            android:textColor="#FF16324C"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layout_auto_search_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_auto_search_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/samsungsharpsans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:lineSpacingExtra="5dp"
                android:shadowColor="#3A000000"
                android:shadowDx="0"
                android:shadowDy="8"
                android:shadowRadius="18"
                android:text="@string/auto_search_state_idle_title"
                android:textColor="#FFF9FBFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progress_auto_search_state"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:indeterminate="true"
                android:indeterminateTint="#FFF9FBFF"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_auto_search_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/samsungone"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="4dp"
            android:textColor="#EAF9FBFF"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/image_auto_search_run"
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_marginTop="18dp"
            android:alpha="0.94"
            android:contentDescription="@null"
            android:src="@drawable/ic_first_launch_autosearch_wifi" />

        <LinearLayout
            android:id="@+id/layout_auto_search_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_first_launch_permission_row"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp">

            <ProgressBar
                android:id="@+id/progress_auto_search"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/text_auto_search_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/samsungone"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="#F4F9FBFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/text_auto_search_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/samsungone"
                android:gravity="center"
                android:includeFontPadding="false"
                android:textColor="#DDF9FBFF"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:overScrollMode="ifContentScrolls">

            <LinearLayout
                android:id="@+id/container_auto_search_profiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <LinearLayout
            android:id="@+id/container_auto_search_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/button_auto_search_primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_first_launch_primary_button"
                android:fontFamily="@font/samsungsharpsans"
                android:text="@string/auto_search_apply_action"
                android:textColor="#FF010102"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/button_auto_search_secondary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_first_launch_inline_button"
                android:fontFamily="@font/samsungsharpsans"
                android:textColor="#FF0B2239"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
