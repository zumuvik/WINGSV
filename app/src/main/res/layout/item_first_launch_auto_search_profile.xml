<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_auto_search_profile"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_first_launch_permission_row"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingTop="13dp"
    android:paddingEnd="18dp"
    android:paddingBottom="13dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_auto_search_profile_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/samsungone"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="#F4F9FBFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_auto_search_profile_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:fontFamily="@font/samsungone"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="#CFF9FBFF"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_auto_search_profile_badge"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_profile_ping_good"
        android:fontFamily="@font/samsungsharpsans"
        android:gravity="center"
        android:minWidth="54dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:textColor="#FFFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progress_auto_search_profile"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="12dp"
        android:indeterminate="true"
        android:indeterminateTint="#FFF9FBFF"
        android:visibility="gone" />
</LinearLayout>
